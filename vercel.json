{
  "version": 2,
  "env": {
    "DATABASE_URL": "file:./dev.db",
    "JWT_SECRET": "interview_flashcard_platform_secret_key_2026",
    "NODE_ENV": "production"
  },
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/src/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["src/prisma/dev.db"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/src/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "frontend/$1"
    }
  ]
}
